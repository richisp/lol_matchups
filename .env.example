# Optional. The League client install directory (the one containing `lockfile`).
# Only needed if you didn't install LoL at the default location.
# LEAGUE_INSTALL_PATH=C:\Riot Games\League of Legends

# Optional. Default tier bracket used by the crawler and as a fallback in the UI.
# See COMMANDS.md for valid values (emerald_plus, all, challenger, ...).
# LOLALYTICS_TIER=emerald_plus

# Optional. When set to "1", scrape_lolalytics.py runs Chromium headlessly.
# Useful for crawling on a server / via cron. Default: 0 (visible browser).
# HEADLESS=0
